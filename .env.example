# ========================================
#  Chiller Plant System - Environment Config
# ========================================

# Copy this file to .env and fill in your values

# ========================================
#  System Settings
# ========================================
ASPNETCORE_ENVIRONMENT=Production
TZ=Asia/Shanghai

# ========================================
#  SQL Server
# ========================================
SQL_SERVER_HOST=sqlserver
SQL_SERVER_PORT=1433
SQL_SERVER_SA_PASSWORD=YourStrong!Passw0rd
SQL_SERVER_DATABASE=ChillerPlantDB

# Connection String (built from above)
# ConnectionStrings__DefaultConnection=Server=sqlserver,1433;Database=ChillerPlantDB;User Id=sa;Password=YourStrong!Passw0rd;TrustServerCertificate=True;MultipleActiveResultSets=true;Connection Timeout=30;

# ========================================
#  Application Insights
# ========================================
APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=your-key-here;IngestionEndpoint=https://your-region.in.applicationinsights.azure.com/
APPLICATIONINSIGHTS_ENABLED=false

# ========================================
#  BACnet Configuration
# ========================================
BACNET_PORT=47808
BACNET_LOCAL_ADDRESS=0.0.0.0
BACNET_POLL_INTERVAL=30

# ========================================
#  BACnet Simulator
# ========================================
SIMULATOR_ENABLED=true
SIMULATOR_TARGET_ADDRESS=backend
SIMULATOR_TARGET_PORT=47808
SIMULATOR_SEND_INTERVAL=30

# Device Counts
SIMULATOR_CENTRIFUGAL_COUNT=3
SIMULATOR_SCREW_COUNT=2
SIMULATOR_COOLING_TOWER_COUNT=8
SIMULATOR_CHILLED_PUMP_COUNT=12
SIMULATOR_COOLING_PUMP_COUNT=12

# Starting BACnet Instance
SIMULATOR_START_INSTANCE=300001

# Performance Curve Configuration
SIMULATOR_LOAD_FACTOR=0.7
SIMULATOR_AMBIENT_TEMP=28.0
SIMULATOR_WET_BULB_TEMP=25.0
SIMULATOR_RANDOM_NOISE=0.05

# Device Performance Curves (COP vs Load Rate)
# Format: JSON array with device type coefficients
# COP = a * (load)^2 + b * load + c
SIMULATOR_PERFORMANCE_CURVES={
  "centrifugal": {"a": -2.5, "b": 3.5, "c": 3.0, "ratedPower": 800, "designCOP": 5.8},
  "screw": {"a": -1.8, "b": 2.8, "c": 2.5, "ratedPower": 500, "designCOP": 5.2},
  "cooling_tower": {"a": -0.5, "b": 1.2, "c": 3.0, "ratedPower": 30, "designCOP": 4.5},
  "chilled_pump": {"a": 0, "b": 0.85, "c": 0, "ratedPower": 75, "efficiency": 0.85},
  "cooling_pump": {"a": 0, "b": 0.85, "c": 0, "ratedPower": 45, "efficiency": 0.85}
}

# ========================================
#  WeChat Alarm
# ========================================
WECHAT_ENABLED=false
WECHAT_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=your-key
WECHAT_AGGREGATE_WINDOW=60

# ========================================
#  Optimization
# ========================================
OPTIMIZATION_MODEL_PATH=/app/Data/neural_network_model.txt
OPTIMIZATION_AUTO_RETRAIN=300
OPTIMIZATION_CALC_INTERVAL=30

# ========================================
#  Docker Compose
# ========================================
COMPOSE_PROJECT_NAME=chiller-plant
COMPOSE_FILE=docker-compose.yml
